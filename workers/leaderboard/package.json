{
  "name": "starsea-leaderboard-worker",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --config wrangler.toml",
    "deploy": "wrangler deploy --config wrangler.toml",
    "test": "node --test test/*.test.mjs",
    "db:init": "wrangler d1 execute e92c11bf-8429-471d-93ea-9fe086c3b3f5 --remote --file=./schema.sql",
